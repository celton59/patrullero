---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>REVOPOL® — Plataforma para Policías en Activo</title>
    <meta name="description" content="REVOPOL® es la plataforma definitiva para policías y revopols en activo. Gestión de turnos, informes, comunicación segura y más." />
    <meta name="keywords" content="revopol, policía, patrulla, gestión policial, turnos policía, app policía" />
    <link rel="canonical" href="https://revopol.app" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="REVOPOL® — Plataforma para Policías en Activo" />
    <meta property="og:description" content="La plataforma definitiva para policías y revopols en activo. Gestión de turnos, informes y comunicación segura." />
    <meta property="og:url" content="https://revopol.app" />
    <meta property="og:site_name" content="REVOPOL®" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:image" content="https://revopol.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:image" content="https://revopol.com/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="REVOPOL® — Plataforma para Policías en Activo" />
    <meta name="twitter:description" content="La plataforma definitiva para policías y revopols en activo." />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "REVOPOL®",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "Plataforma de gestión integral para policías y revopols en activo.",
        "offers": {
          "@type": "Offer",
          "price": "29.90",
          "priceCurrency": "EUR"
        }
      }
    </script>

    <!-- Fonts — preload to eliminate FOUT flicker -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
      /* Anti-flicker: hide body until fonts + styles are ready */
      html { font-family: 'Inter', system-ui, sans-serif; scroll-behavior: smooth; }
      body { background: #0a0a0a; color: #e2e8f0; opacity: 0; transition: opacity 0.15s ease; }
      body.ready { opacity: 1; }

      /* Asphalt texture background */
      .bg-grid {
        background-color: #0a0a0a;
        background-image:
          /* Grain noise layer */
          url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"),
          /* Subtle aggregate specks */
          radial-gradient(ellipse 1px 1px at 13px 17px, rgba(255,255,255,0.03) 0%, transparent 100%),
          radial-gradient(ellipse 1px 1px at 47px 29px, rgba(255,255,255,0.025) 0%, transparent 100%),
          radial-gradient(ellipse 1px 1px at 31px 43px, rgba(255,255,255,0.02) 0%, transparent 100%),
          /* Deep asphalt gradient */
          linear-gradient(180deg, #0a0a0a 0%, #0d0d0d 40%, #080808 70%, #0a0a0a 100%);
        background-size: 256px 256px, 60px 50px, 60px 50px, 60px 50px, 100% 100%;
      }

      /* Animations */
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 20px rgba(33,89,226,0.3); }
        50% { box-shadow: 0 0 40px rgba(33,89,226,0.6); }
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
      @keyframes slide-in-left {
        from { opacity: 0; transform: translateX(-40px); }
        to { opacity: 1; transform: translateX(0); }
      }
      @keyframes counter-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .animate-on-scroll { opacity: 0; transform: translateY(30px); transition: all 0.7s cubic-bezier(0.16,1,0.3,1); }
      .animate-on-scroll.visible { opacity: 1; transform: translateY(0); }

      /* Bento card hover */
      .bento-card {
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
      }
      .bento-card:hover {
        transform: scale(1.02) translateY(-2px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
      }

      /* Apple-style cinematic scroll */
      .apple-feature {
        opacity: 0;
        transform: translateY(60px) scale(0.97);
        filter: blur(4px);
        transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .apple-feature.apple-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
      .animate-fade-up { animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
      .animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }
      .animate-float { animation: float 4s ease-in-out infinite; }
      .animate-slide-left { animation: slide-in-left 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
      .delay-100 { animation-delay: 0.1s; }
      .delay-200 { animation-delay: 0.2s; }
      .delay-300 { animation-delay: 0.3s; }
      .delay-400 { animation-delay: 0.4s; }
      .delay-500 { animation-delay: 0.5s; }

      /* FAQ accordion */
      .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.16,1,0.3,1); }
      .faq-answer.open { max-height: 500px; }
      .faq-chevron { transition: transform 0.3s ease; }
      .faq-chevron.rotated { transform: rotate(180deg); }

      /* Card flip */
      .flip-card { perspective: 1000px; }
      .flip-card-inner { transition: transform 0.6s; transform-style: preserve-3d; }
      .flip-card:hover .flip-card-inner { transform: rotateY(180deg); }
      .flip-card-front, .flip-card-back { backface-visibility: hidden; }
      .flip-card-back { transform: rotateY(180deg); }

      /* Mobile nav */
      .mobile-nav { transform: translateY(100%); transition: transform 0.3s ease; }
      .mobile-nav.visible { transform: translateY(0); }

      /* ===== FLASHLIGHT EFFECT ===== */
      /* Full-screen dark overlay with a punched-out beam hole */
      .flashlight-dark {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
        background: rgba(0,0,0,0.92);
        /* The beam hole — mask punches through the darkness */
        -webkit-mask-image: radial-gradient(
          ellipse var(--beam-w, 160px) var(--beam-h, 180px) at var(--fx, 50%) var(--fy, 50%),
          transparent 0%,
          rgba(0,0,0,0.1) 50%,
          rgba(0,0,0,0.6) 70%,
          black 85%
        );
        mask-image: radial-gradient(
          ellipse var(--beam-w, 160px) var(--beam-h, 180px) at var(--fx, 50%) var(--fy, 50%),
          transparent 0%,
          rgba(0,0,0,0.1) 50%,
          rgba(0,0,0,0.6) 70%,
          black 85%
        );
      }
      .flashlight-dark.active { opacity: 1; }

      /* Images layer — sits just below the dark overlay */
      .flashlight-bg {
        position: fixed;
        inset: 0;
        z-index: 9997;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
      }
      .flashlight-bg.active { opacity: 1; }

      /* Warm cone of light — brightest in center, fades out */
      .flashlight-cone {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
        background: radial-gradient(
          ellipse var(--beam-w, 160px) var(--beam-h, 180px) at var(--fx, 50%) var(--fy, 50%),
          rgba(255,248,220,0.12) 0%,
          rgba(255,235,180,0.06) 30%,
          rgba(255,220,150,0.02) 55%,
          transparent 75%
        );
      }
      .flashlight-cone.active { opacity: 1; }

      /* Lens flare / hotspot at center of beam */
      .flashlight-hotspot {
        position: fixed;
        width: 40px;
        height: 40px;
        z-index: 9999;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.4s ease;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(255,255,240,0.15) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        filter: blur(8px);
      }
      .flashlight-hotspot.active { opacity: 1; }

      .flashlight-btn {
        position: fixed;
        bottom: 200px;
        right: 20px;
        z-index: 10000;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        color: rgba(255,255,255,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
        opacity: 0.5;
      }
      .flashlight-btn:hover { background: rgba(255,255,255,0.12); color: white; opacity: 1; }
      .flashlight-btn.on {
        background: rgba(255,200,50,0.15);
        border-color: rgba(255,200,50,0.3);
        color: #ffd060;
        box-shadow: 0 0 20px rgba(255,200,50,0.2);
      }

      @media (min-width: 1024px) {
        .flashlight-btn { bottom: 88px; right: 24px; }
      }

      /* Apple-style pill nav */
      .pill-nav {
        background: rgba(10,10,10,0.65);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 4px 30px rgba(0,0,0,0.3), inset 0 0.5px 0 rgba(255,255,255,0.06);
        transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
      }
      .pill-nav.scrolled {
        background: rgba(10,10,10,0.85);
        border-color: rgba(255,255,255,0.1);
        box-shadow: 0 8px 40px rgba(0,0,0,0.5), inset 0 0.5px 0 rgba(255,255,255,0.08);
      }
      .pill-nav a.nav-link {
        position: relative;
        padding: 6px 12px;
        border-radius: 8px;
        transition: all 0.2s ease;
      }
      .pill-nav a.nav-link:hover {
        background: rgba(255,255,255,0.08);
      }
      .pill-cta {
        background: rgba(33,89,226,0.9);
        backdrop-filter: blur(8px);
        transition: all 0.2s ease;
      }
      .pill-cta:hover {
        background: rgba(33,89,226,1);
        box-shadow: 0 0 20px rgba(33,89,226,0.4);
      }

      /* ===== 1. SIREN PULSE ===== */
      @keyframes siren-pulse {
        0%, 100% { background: radial-gradient(ellipse at 30% 50%, rgba(33,89,226,0.15) 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, rgba(220,38,38,0.08) 0%, transparent 60%); }
        50% { background: radial-gradient(ellipse at 30% 50%, rgba(220,38,38,0.08) 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, rgba(33,89,226,0.15) 0%, transparent 60%); }
      }
      .siren-bg { animation: siren-pulse 4s ease-in-out infinite; position: absolute; inset: 0; pointer-events: none; z-index: 0; }

      /* ===== 2. CLASSIFIED STAMP ===== */
      .classified-stamp { position: relative; }
      .classified-stamp::before {
        content: 'CONFIDENCIAL';
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-15deg);
        font-size: 4rem; font-weight: 900; color: rgba(220,38,38,0.06);
        letter-spacing: 0.3em; text-transform: uppercase; pointer-events: none; z-index: 0;
        opacity: 1; transition: opacity 0.8s ease;
      }
      .classified-stamp.visible::before { opacity: 0; }

      /* ===== 4. BADGE CARD (PRICING) ===== */
      .badge-card {
        position: relative;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
        border: 2px solid rgba(33,89,226,0.5);
        border-radius: 50% 50% 50% 50% / 35% 35% 65% 65%;
        padding: 3rem 2.5rem 2.5rem;
        overflow: hidden;
      }
      .badge-card::before {
        content: ''; position: absolute; inset: 4px;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 50% 50% 50% 50% / 35% 35% 65% 65%;
        pointer-events: none;
      }
      .badge-card:hover { border-color: rgba(33,89,226,0.8); box-shadow: 0 0 40px rgba(33,89,226,0.2); }
      .badge-shine {
        position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.03) 50%, transparent 60%);
        transition: transform 0.6s ease;
      }
      .badge-card:hover .badge-shine { transform: translateX(30%) translateY(30%); }

      /* ===== 6. WALKIE-TALKIE TESTIMONIALS ===== */
      .walkie-card { position: relative; background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%); border: 1px solid rgba(255,255,255,0.06); border-radius: 1rem; padding: 1.5rem; }
      .walkie-card::before { content: ''; position: absolute; top: 0.75rem; right: 0.75rem; width: 8px; height: 8px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.6); animation: radio-blink 2s ease-in-out infinite; }
      @keyframes radio-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
      .walkie-card .radio-wave { display: flex; align-items: center; gap: 2px; margin-bottom: 0.75rem; }
      .walkie-card .radio-wave span { display: block; width: 3px; border-radius: 2px; background: #2159E2; }
      @keyframes wave-anim { 0%, 100% { height: 8px; } 50% { height: 16px; } }
    </style>
  </head>

  <body class="bg-grid min-h-screen antialiased">

    <!-- Spain map overlay with active study points -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-30">
      <svg viewBox="0 0 800 700" class="w-full h-full" preserveAspectRatio="xMidYMid meet">
        <!-- Simplified Spain outline -->
        <path d="M280,120 L320,100 L380,90 L440,95 L500,80 L540,90 L580,110 L600,140 L620,160 L640,200 L630,240 L600,280 L580,320 L560,360 L540,380 L500,400 L460,420 L420,430 L380,420 L340,400 L300,380 L270,350 L250,310 L240,270 L250,230 L260,190 L270,150 Z" fill="none" stroke="rgba(33,89,226,0.08)" stroke-width="1"/>
        <!-- Study points (cities) -->
        <circle cx="380" cy="310" r="3" fill="#2159E2" opacity="0.6"><animate attributeName="r" values="3;5;3" dur="3s" repeatCount="indefinite"/></circle>
        <circle cx="560" cy="280" r="2.5" fill="#2159E2" opacity="0.5"><animate attributeName="r" values="2.5;4.5;2.5" dur="3.5s" repeatCount="indefinite"/></circle>
        <circle cx="310" cy="250" r="2" fill="#2159E2" opacity="0.4"><animate attributeName="r" values="2;4;2" dur="4s" repeatCount="indefinite"/></circle>
        <circle cx="480" cy="200" r="2.5" fill="#2159E2" opacity="0.5"><animate attributeName="r" values="2.5;4.5;2.5" dur="2.8s" repeatCount="indefinite"/></circle>
        <circle cx="420" cy="380" r="2" fill="#2159E2" opacity="0.4"><animate attributeName="r" values="2;4;2" dur="3.2s" repeatCount="indefinite"/></circle>
        <circle cx="340" cy="180" r="2" fill="#5A2177" opacity="0.4"><animate attributeName="r" values="2;3.5;2" dur="3.8s" repeatCount="indefinite"/></circle>
        <circle cx="520" cy="340" r="2.5" fill="#5A2177" opacity="0.5"><animate attributeName="r" values="2.5;4;2.5" dur="3.3s" repeatCount="indefinite"/></circle>
        <circle cx="440" cy="150" r="2" fill="#2159E2" opacity="0.3"><animate attributeName="r" values="2;3.5;2" dur="4.2s" repeatCount="indefinite"/></circle>
      </svg>
    </div>

    <!-- ============ FLASHLIGHT BACKGROUND IMAGES (revealed by beam) ============ -->
    <div id="flashlight-bg" class="flashlight-bg">
      <!-- Scattered images behind the dark overlay — only visible through the beam -->
      <img src="https://images.unsplash.com/photo-1557862921-37829c790f19?w=300&q=80" alt="" class="absolute top-[10%] left-[5%] w-48 h-32 object-cover rounded-xl opacity-60 rotate-[-3deg]" />
      <img src="https://images.unsplash.com/photo-1589578228447-e1a4e481c6c8?w=300&q=80" alt="" class="absolute top-[8%] right-[10%] w-56 h-36 object-cover rounded-xl opacity-50 rotate-[2deg]" />
      <img src="https://images.unsplash.com/photo-1453873531674-2151bcd01707?w=300&q=80" alt="" class="absolute top-[30%] left-[15%] w-44 h-28 object-cover rounded-xl opacity-55 rotate-[4deg]" />
      <img src="https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=300&q=80" alt="" class="absolute top-[35%] right-[5%] w-52 h-34 object-cover rounded-xl opacity-45 rotate-[-2deg]" />
      <img src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?w=300&q=80" alt="" class="absolute top-[55%] left-[8%] w-40 h-28 object-cover rounded-xl opacity-50 rotate-[1deg]" />
      <img src="https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=300&q=80" alt="" class="absolute top-[50%] left-[40%] w-48 h-32 object-cover rounded-xl opacity-55 rotate-[-4deg]" />
      <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=300&q=80" alt="" class="absolute top-[60%] right-[12%] w-44 h-30 object-cover rounded-xl opacity-50 rotate-[3deg]" />
      <img src="https://images.unsplash.com/photo-1541339907198-e08756dedf3f?w=300&q=80" alt="" class="absolute top-[78%] left-[20%] w-52 h-34 object-cover rounded-xl opacity-45 rotate-[-1deg]" />
      <img src="https://images.unsplash.com/photo-1606761568499-6d2451b23c66?w=300&q=80" alt="" class="absolute top-[75%] right-[8%] w-48 h-32 object-cover rounded-xl opacity-60 rotate-[2deg]" />
      <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=300&q=80" alt="" class="absolute top-[20%] left-[50%] w-40 h-28 object-cover rounded-xl opacity-40 rotate-[-3deg]" />
    </div>

    <!-- ============ FLASHLIGHT LAYERS ============ -->
    <div id="flashlight-dark" class="flashlight-dark"></div>
    <div id="flashlight-cone" class="flashlight-cone"></div>
    <div id="flashlight-hotspot" class="flashlight-hotspot"></div>
    <button id="flashlight-toggle" class="flashlight-btn" aria-label="Activar linterna">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
      </svg>
    </button>

    <!-- ============ HEADER — Apple Pill Nav ============ -->
    <header id="header" class="fixed top-0 left-0 right-0 z-50 pointer-events-none">
      <div class="flex justify-center pt-4 px-4">
        <div id="pill" class="pill-nav pointer-events-auto rounded-full px-2 py-1.5 flex items-center gap-1">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-2 pl-2 pr-3">
            <div class="w-7 h-7 rounded-full bg-gradient-to-br from-[#2159E2] to-[#5A2177] flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <span class="text-sm font-bold tracking-wide uppercase text-white hidden sm:inline">REVOPOL®</span>
          </a>

          <!-- Divider -->
          <div class="hidden lg:block w-px h-5 bg-white/10"></div>

          <!-- Desktop nav links -->
          <nav class="hidden lg:flex items-center gap-0.5">
            <a href="#features" class="nav-link text-[13px] font-medium text-slate-400 hover:text-white transition-colors">Funciones</a>
            <a href="#plataforma" class="nav-link text-[13px] font-medium text-slate-400 hover:text-white transition-colors">Plataforma</a>
            <a href="#testimonios" class="nav-link text-[13px] font-medium text-slate-400 hover:text-white transition-colors">Testimonios</a>
            <a href="#precio" class="nav-link text-[13px] font-medium text-slate-400 hover:text-white transition-colors">Precio</a>
            <a href="#faq" class="nav-link text-[13px] font-medium text-slate-400 hover:text-white transition-colors">FAQ</a>
          </nav>

          <!-- Divider -->
          <div class="hidden lg:block w-px h-5 bg-white/10"></div>

          <!-- Live counter -->
          <div class="hidden lg:flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 mr-1">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <span id="live-counter" class="text-[11px] font-bold text-emerald-400">347</span>
            <span class="text-[10px] text-emerald-400/70">online</span>
