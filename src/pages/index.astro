---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>PATRULLERO — Plataforma para Policías en Activo</title>
    <meta name="description" content="Patrullero es la plataforma definitiva para policías y patrulleros en activo. Gestión de turnos, informes, comunicación segura y más." />
    <meta name="keywords" content="patrullero, policía, patrulla, gestión policial, turnos policía, app policía" />
    <link rel="canonical" href="https://patrullero.app" />

    <!-- OG -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="PATRULLERO — Plataforma para Policías en Activo" />
    <meta property="og:description" content="La plataforma definitiva para policías y patrulleros en activo. Gestión de turnos, informes y comunicación segura." />
    <meta property="og:url" content="https://patrullero.app" />
    <meta property="og:site_name" content="Patrullero" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="PATRULLERO — Plataforma para Policías en Activo" />
    <meta name="twitter:description" content="La plataforma definitiva para policías y patrulleros en activo." />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Patrullero",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "description": "Plataforma de gestión integral para policías y patrulleros en activo.",
        "offers": {
          "@type": "Offer",
          "price": "29.90",
          "priceCurrency": "EUR"
        }
      }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <style>
      html { font-family: 'Inter', system-ui, sans-serif; scroll-behavior: smooth; }
      body { background: #0a0a0a; color: #e2e8f0; }

      /* Asphalt texture background */
      .bg-grid {
        background-color: #0a0a0a;
        background-image:
          /* Grain noise layer */
          url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"),
          /* Subtle aggregate specks */
          radial-gradient(ellipse 1px 1px at 13px 17px, rgba(255,255,255,0.03) 0%, transparent 100%),
          radial-gradient(ellipse 1px 1px at 47px 29px, rgba(255,255,255,0.025) 0%, transparent 100%),
          radial-gradient(ellipse 1px 1px at 31px 43px, rgba(255,255,255,0.02) 0%, transparent 100%),
          /* Deep asphalt gradient */
          linear-gradient(180deg, #0a0a0a 0%, #0d0d0d 40%, #080808 70%, #0a0a0a 100%);
        background-size: 256px 256px, 60px 50px, 60px 50px, 60px 50px, 100% 100%;
      }

      /* Animations */
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes pulse-glow {
        0%, 100% { box-shadow: 0 0 20px rgba(33,89,226,0.3); }
        50% { box-shadow: 0 0 40px rgba(33,89,226,0.6); }
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
      }
      @keyframes slide-in-left {
        from { opacity: 0; transform: translateX(-40px); }
        to { opacity: 1; transform: translateX(0); }
      }
      @keyframes counter-up {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .animate-on-scroll { opacity: 0; transform: translateY(30px); transition: all 0.7s cubic-bezier(0.16,1,0.3,1); }
      .animate-on-scroll.visible { opacity: 1; transform: translateY(0); }
      .animate-fade-up { animation: fade-up 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
      .animate-pulse-glow { animation: pulse-glow 3s ease-in-out infinite; }
      .animate-float { animation: float 4s ease-in-out infinite; }
      .animate-slide-left { animation: slide-in-left 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
      .delay-100 { animation-delay: 0.1s; }
      .delay-200 { animation-delay: 0.2s; }
      .delay-300 { animation-delay: 0.3s; }
      .delay-400 { animation-delay: 0.4s; }
      .delay-500 { animation-delay: 0.5s; }

      /* FAQ accordion */
      .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.16,1,0.3,1); }
      .faq-answer.open { max-height: 500px; }
      .faq-chevron { transition: transform 0.3s ease; }
      .faq-chevron.rotated { transform: rotate(180deg); }

      /* Card flip */
      .flip-card { perspective: 1000px; }
      .flip-card-inner { transition: transform 0.6s; transform-style: preserve-3d; }
      .flip-card:hover .flip-card-inner { transform: rotateY(180deg); }
      .flip-card-front, .flip-card-back { backface-visibility: hidden; }
      .flip-card-back { transform: rotateY(180deg); }

      /* Mobile nav */
      .mobile-nav { transform: translateY(100%); transition: transform 0.3s ease; }
      .mobile-nav.visible { transform: translateY(0); }

      /* Scroll-based header */
      .header-bg { background: transparent; transition: background 0.3s ease, box-shadow 0.3s ease; }
      .header-bg.scrolled { background: rgba(2,6,23,0.95); box-shadow: 0 1px 0 rgba(51,65,85,0.3); backdrop-filter: blur(12px); }
    </style>
  </head>

  <body class="bg-grid min-h-screen antialiased">

    <!-- ============ HEADER ============ -->
    <header id="header" class="header-bg fixed top-0 left-0 right-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 lg:h-20">
          <!-- Logo -->
          <a href="#" class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-[#2159E2] to-[#5A2177] flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
              </svg>
            </div>
            <span class="text-lg font-extrabold tracking-wider uppercase text-white">Patrullero</span>
          </a>

          <!-- Desktop nav -->
          <nav class="hidden lg:flex items-center gap-8">
            <a href="#features" class="text-sm font-medium text-slate-400 hover:text-white transition-colors uppercase tracking-wider">Funciones</a>
            <a href="#plataforma" class="text-sm font-medium text-slate-400 hover:text-white transition-colors uppercase tracking-wider">Plataforma</a>
            <a href="#testimonios" class="text-sm font-medium text-slate-400 hover:text-white transition-colors uppercase tracking-wider">Testimonios</a>
            <a href="#precio" class="text-sm font-medium text-slate-400 hover:text-white transition-colors uppercase tracking-wider">Precio</a>
            <a href="#faq" class="text-sm font-medium text-slate-400 hover:text-white transition-colors uppercase tracking-wider">FAQ</a>
          </nav>

          <!-- Desktop CTA -->
          <div class="hidden lg:flex items-center gap-4">
            <a href="#precio" class="bg-[#2159E2] hover:bg-[#2159E2]/80 text-white text-sm font-bold uppercase tracking-widest px-6 py-2.5 rounded-lg transition-all">
              Empezar
            </a>
          </div>

          <!-- Mobile burger -->
          <button id="menu-toggle" class="lg:hidden p-2 text-slate-400 hover:text-white" aria-label="Abrir menú">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path id="burger-icon" stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="lg:hidden hidden bg-slate-950/98 border-t border-slate-800">
        <div class="px-4 py-6 space-y-4">
          <a href="#features" class="block text-sm font-medium text-slate-300 hover:text-white uppercase tracking-wider py-2">Funciones</a>
          <a href="#plataforma" class="block text-sm font-medium text-slate-300 hover:text-white uppercase tracking-wider py-2">Plataforma</a>
          <a href="#testimonios" class="block text-sm font-medium text-slate-300 hover:text-white uppercase tracking-wider py-2">Testimonios</a>
          <a href="#precio" class="block text-sm font-medium text-slate-300 hover:text-white uppercase tracking-wider py-2">Precio</a>
          <a href="#faq" class="block text-sm font-medium text-slate-300 hover:text-white uppercase tracking-wider py-2">FAQ</a>
          <a href="#precio" class="block bg-[#2159E2] hover:bg-[#2159E2]/80 text-white text-sm font-bold uppercase tracking-widest px-6 py-3 rounded-lg text-center mt-4">Empezar Ahora</a>
        </div>
      </div>
    </header>

    <main>

      <!-- ============ HERO ============ -->
      <section class="relative pt-28 lg:pt-36 pb-16 lg:pb-24 overflow-hidden">
        <!-- Glow background -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-[#2159E2]/10 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute top-20 right-0 w-[400px] h-[400px] bg-[#5A2177]/10 rounded-full blur-[100px] pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Left -->
            <div>
              <!-- Badge -->
              <div class="inline-flex items-center gap-2 px-4 py-2 border border-[#2159E2]/30 rounded-full bg-[#2159E2]/10 mb-8 animate-fade-up">
                <span class="w-2 h-2 rounded-full bg-[#2159E2] animate-pulse"></span>
                <span class="text-xs font-semibold text-[#2159E2] uppercase tracking-widest">Acceso Exclusivo para Policías</span>
              </div>

              <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black uppercase tracking-tight leading-[0.95] mb-6 animate-fade-up delay-100">
                <span class="text-white">La App que</span><br />
                <span class="bg-gradient-to-r from-[#2159E2] to-[#5A2177] bg-clip-text text-transparent">Todo Patrullero</span><br />
                <span class="text-white">Necesita</span>
              </h1>

              <p class="text-lg text-slate-400 max-w-lg mb-8 animate-fade-up delay-200">
                Gestiona turnos, informes, comunicaciones y operativos desde una sola plataforma diseñada por y para policías en activo.
              </p>

              <!-- CTAs -->
              <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-up delay-300">
                <a href="#precio" class="bg-[#2159E2] hover:bg-[#2159E2]/80 text-white font-bold uppercase tracking-widest px-8 py-4 rounded-lg text-sm text-center transition-all animate-pulse-glow">
                  Comenzar Ahora
                </a>
                <a href="#plataforma" class="border border-slate-700 hover:border-slate-500 text-white font-bold uppercase tracking-widest px-8 py-4 rounded-lg text-sm text-center transition-all flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" /></svg>
                  Ver Demo
                </a>
              </div>

              <!-- Stats -->
              <div class="grid grid-cols-3 gap-6 animate-fade-up delay-400">
                <div>
                  <div class="text-2xl sm:text-3xl font-black text-white" data-counter="2500">0</div>
                  <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Agentes Activos</div>
                </div>
                <div>
                  <div class="text-2xl sm:text-3xl font-black text-white" data-counter="150">0</div>
                  <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Comisarías</div>
                </div>
                <div>
                  <div class="text-2xl sm:text-3xl font-black text-white" data-counter="98">0</div>
                  <div class="text-xs text-slate-500 uppercase tracking-wider mt-1 flex items-center gap-1">Satisfacción <span class="text-[#2159E2]">%</span></div>
                </div>
              </div>
            </div>

            <!-- Right: Platform mockup -->
            <div class="relative animate-fade-up delay-300">
              <div class="relative animate-float">
                <!-- Phone mockup -->
                <div class="bg-slate-900 border border-slate-700 rounded-3xl p-3 shadow-2xl shadow-[#2159E2]/10 max-w-sm mx-auto">
                  <div class="bg-slate-950 rounded-2xl overflow-hidden">
                    <!-- Status bar -->
                    <div class="flex items-center justify-between px-5 py-3 bg-slate-900/80">
                      <span class="text-xs text-slate-500 font-medium">09:41</span>
                      <div class="flex gap-1.5">
                        <div class="w-3.5 h-2 rounded-sm bg-slate-600"></div>
                        <div class="w-3.5 h-2 rounded-sm bg-slate-600"></div>
                        <div class="w-4 h-2 rounded-sm bg-white"></div>
                      </div>
                    </div>
                    <!-- App header -->
                    <div class="px-5 py-4 border-b border-slate-800">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-[#2159E2] to-[#5A2177] flex items-center justify-center">
                          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
                        </div>
                        <div>
                          <div class="text-sm font-bold text-white uppercase tracking-wide">Patrullero</div>
                          <div class="text-[10px] text-green-400 flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-400"></span> En servicio</div>
                        </div>
                      </div>
                    </div>
                    <!-- Mock content -->
                    <div class="p-5 space-y-4">
                      <div class="bg-slate-900/80 rounded-xl p-4 border border-slate-800">
                        <div class="text-[10px] text-slate-500 uppercase tracking-wider mb-2">Turno Actual</div>
                        <div class="text-sm font-bold text-white">Mañana — 06:00 a 14:00</div>
                        <div class="text-xs text-slate-400 mt-1">Zona 4B — Sector Centro</div>
                        <div class="mt-3 w-full h-1.5 bg-slate-800 rounded-full overflow-hidden">
                          <div class="h-full w-3/5 bg-gradient-to-r from-[#2159E2] to-[#5A2177] rounded-full"></div>
                        </div>
                      </div>
                      <div class="grid grid-cols-2 gap-3">
                        <div class="bg-slate-900/80 rounded-xl p-3 border border-slate-800 text-center">
                          <div class="text-lg font-black text-[#2159E2]">12</div>
                          <div class="text-[10px] text-slate-500 uppercase">Informes</div>
                        </div>
                        <div class="bg-slate-900/80 rounded-xl p-3 border border-slate-800 text-center">
                          <div class="text-lg font-black text-[#5A2177]">3</div>
                          <div class="text-[10px] text-slate-500 uppercase">Alertas</div>
                        </div>
                      </div>
                      <div class="bg-[#2159E2]/10 border border-[#2159E2]/30 rounded-xl p-3 flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-[#2159E2]/20 flex items-center justify-center shrink-0">
                          <svg class="w-4 h-4 text-[#2159E2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                        </div>
                        <div>
                          <div class="text-xs font-bold text-white">Nueva directiva operativa</div>
                          <div class="text-[10px] text-slate-400">Hace 5 min — Jefatura</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Floating badges -->
                <div class="absolute -left-4 top-1/4 bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 shadow-xl hidden lg:flex items-center gap-2 animate-float" style="animation-delay: 0.5s;">
                  <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span class="text-xs font-bold text-white">Cifrado E2E</span>
                </div>
                <div class="absolute -right-4 bottom-1/3 bg-slate-900 border border-slate-700 rounded-xl px-4 py-2.5 shadow-xl hidden lg:flex items-center gap-2 animate-float" style="animation-delay: 1s;">
                  <svg class="w-5 h-5 text-[#2159E2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
                  <span class="text-xs font-bold text-white">100% Seguro</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ TRUST BADGES ============ -->
      <section class="border-y border-slate-800 bg-slate-900/30 py-8 lg:py-10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex flex-wrap justify-center gap-6 lg:gap-12">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[#2159E2]/10 border border-[#2159E2]/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-[#2159E2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Solo Policía Nacional</div>
                <div class="text-xs text-slate-500">Acceso verificado</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[#2159E2]/10 border border-[#2159E2]/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-[#2159E2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Policías en Activo</div>
                <div class="text-xs text-slate-500">+2.500 agentes</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[#2159E2]/10 border border-[#2159E2]/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-[#2159E2]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
              </div>
              <div>
                <div class="text-sm font-bold text-white">Datos Cifrados</div>
                <div class="text-xs text-slate-500">Cifrado extremo a extremo</div>
              </div>
            </div>
