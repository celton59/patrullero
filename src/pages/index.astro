    <script>
      // Pill nav scroll effect
      const pill = document.getElementById('pill');
      window.addEventListener('scroll', () => {
        pill?.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });

      // Mobile menu toggle
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      menuToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
      });

      // Close mobile menu on link click
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => mobileMenu?.classList.add('hidden'));
      });

      // Mobile bottom nav visibility
      const mobileBottomNav = document.getElementById('mobile-bottom-nav');
      let lastScrollY = 0;
      window.addEventListener('scroll', () => {
        if (window.scrollY > 100) {
          mobileBottomNav?.classList.add('visible');
        } else {
          mobileBottomNav?.classList.remove('visible');
        }
        lastScrollY = window.scrollY;
      }, { passive: true });

      // FAQ accordion
      document.querySelectorAll('.faq-toggle').forEach(button => {
        button.addEventListener('click', () => {
          const item = button.closest('.faq-item');
          const answer = item?.querySelector('.faq-answer');
          const chevron = item?.querySelector('.faq-chevron');
          const isOpen = answer?.classList.contains('open');

          // Close all
          document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
          document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotated'));

          // Toggle current
          if (!isOpen) {
            answer?.classList.add('open');
            chevron?.classList.add('rotated');
          }
        });
      });

      // Scroll animations with IntersectionObserver
      const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

      // Apple-style cinematic scroll animations
      const appleObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = parseInt(entry.target.dataset.delay || '0', 10);
            setTimeout(() => {
              entry.target.classList.add('apple-visible');
            }, delay);
            appleObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -80px 0px' });

      document.querySelectorAll('.apple-feature').forEach(el => appleObserver.observe(el));

      // Counter animation
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseInt(el.dataset.counter || '0', 10);
            let current = 0;
            const increment = Math.ceil(target / 60);
            const timer = setInterval(() => {
              current += increment;
              if (current >= target) {
                current = target;
                clearInterval(timer);
              }
              el.textContent = current.toLocaleString('es-ES') + (el.closest('.flex') ? '' : '+');
            }, 25);
            counterObserver.unobserve(el);
          }
        });
      }, { threshold: 0.5 });

      document.querySelectorAll('[data-counter]').forEach(el => counterObserver.observe(el));

      // ===== FLASHLIGHT EFFECT =====
      (() => {
        const btn = document.getElementById('flashlight-toggle');
        const bg = document.getElementById('flashlight-bg');
        const dark = document.getElementById('flashlight-dark');
        const cone = document.getElementById('flashlight-cone');
        const hotspot = document.getElementById('flashlight-hotspot');
        if (!btn) return;

        let isOn = false;
        let gyroAvailable = false;
        let gyroPermissionGranted = false;

        // Set CSS custom properties for beam position
        const setBeam = (x, y) => {
          const fx = x + 'px', fy = y + 'px';
          [dark, cone, bg].forEach(el => {
            if (!el) return;
            el.style.setProperty('--fx', fx);
            el.style.setProperty('--fy', fy);
          });
          if (hotspot) {
            hotspot.style.left = fx;
            hotspot.style.top = fy;
          }
        };

        // Desktop: follow mouse
        const onMouse = (e) => {
          if (!isOn) return;
          setBeam(e.clientX, e.clientY);
        };

        // Mobile: gyroscope
        const onOrientation = (e) => {
          if (!isOn) return;
          // gamma = left/right tilt (-90 to 90)
          // beta = front/back tilt (-180 to 180)
          const gamma = e.gamma || 0; // left-right
          const beta = e.beta || 0;   // front-back

          // Map tilt to screen coordinates
          // Center = phone held at ~45° (beta≈45), flat = looking down
          const w = window.innerWidth;
          const h = window.innerHeight;

          // gamma: -45..+45 → 0..w  (clamped)
          const clampGamma = Math.max(-45, Math.min(45, gamma));
          const x = ((clampGamma + 45) / 90) * w;

          // beta: 20..70 → 0..h (phone held normally ~20-70°)
          const clampBeta = Math.max(20, Math.min(70, beta));
          const y = ((clampBeta - 20) / 50) * h;

          setBeam(x, y);
        };

        // Request gyro permission (iOS)
        const requestGyro = async () => {
          if (typeof DeviceOrientationEvent !== 'undefined' &&
              typeof DeviceOrientationEvent.requestPermission === 'function') {
            try {
              const perm = await DeviceOrientationEvent.requestPermission();
              if (perm === 'granted') {
                gyroPermissionGranted = true;
                window.addEventListener('deviceorientation', onOrientation, { passive: true });
              }
            } catch (e) {
              console.warn('Gyro permission denied');
            }
          } else {
            // Android or desktop — just add listener (won't fire on desktop)
            gyroPermissionGranted = true;
            window.addEventListener('deviceorientation', onOrientation, { passive: true });
          }
        };

        // Check if device has gyro
        const checkGyro = () => {
          return 'DeviceOrientationEvent' in window &&
            ('ontouchstart' in window || navigator.maxTouchPoints > 0);
        };
        gyroAvailable = checkGyro();

        // Toggle
        btn.addEventListener('click', async () => {
          isOn = !isOn;
          [bg, dark, cone, hotspot].forEach(el => el?.classList.toggle('active', isOn));
          btn.classList.toggle('on', isOn);

          if (isOn) {
            // Set initial position to center
            setBeam(window.innerWidth / 2, window.innerHeight / 2);

            if (gyroAvailable && !gyroPermissionGranted) {
              await requestGyro();
            }
            document.addEventListener('mousemove', onMouse, { passive: true });
          } else {
            document.removeEventListener('mousemove', onMouse);
          }
        });

        // Also allow mouse to work even with gyro (hybrid devices)
        // Desktop always uses mouse, mobile uses gyro
      })();

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          if (href && href !== '#') {
            e.preventDefault();
            const target = document.querySelector(href);
            target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Live counter (fluctuates randomly for social proof)
      const liveEl = document.getElementById('live-counter');
      if (liveEl) {
        const base = 280 + Math.floor(Math.random() * 120);
        liveEl.textContent = base;
        setInterval(() => {
          const current = parseInt(liveEl.textContent) || base;
          const delta = Math.floor(Math.random() * 7) - 3; // -3 to +3
          liveEl.textContent = Math.max(base - 50, Math.min(base + 80, current + delta));
        }, 4000);
      }

      // Classified stamp: fade out watermark when section scrolls into view
      const stampObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            stampObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });
      document.querySelectorAll('.classified-stamp').forEach(el => stampObserver.observe(el));

      // Anti-flicker: reveal body once fonts are loaded (or after 300ms safety timeout)
      const reveal = () => document.body.classList.add('ready');
      if (document.fonts && document.fonts.ready) {
        document.fonts.ready.then(reveal);
      }
      // Safety: reveal after 300ms max even if fonts are slow
      setTimeout(reveal, 300);
    </script>

  </body>
</html>
